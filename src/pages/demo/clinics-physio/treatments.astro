---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/clinics-physio/BrandNav';
import Footer from '../../../components/demos/clinics-physio/Footer';
import TreatmentsList from '../../../components/demos/clinics-physio/TreatmentsList';
import ChatWidget from '../../../components/demos/clinics-physio/ChatWidget';
---

<Layout title="Treatments & Prices — Verdant Physio">
  <Header client:load />
  <BrandNav client:load />
  <div class="min-h-screen bg-emerald-50/40 font-sans">
    <section class="pt-32 pb-12 bg-gradient-to-b from-emerald-700 to-teal-600">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block px-3 py-1 rounded-full bg-white/15 text-emerald-50 text-xs font-medium mb-4">Treatments & Prices</span>
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white mb-3">Care for every kind of body</h1>
        <p class="text-emerald-50/90 max-w-2xl mx-auto">Transparent pricing, no hidden fees. Filter by what you need — and book the moment you’re ready.</p>
      </div>
    </section>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <TreatmentsList client:load />
      <p class="text-center text-xs text-slate-400 mt-10 max-w-xl mx-auto">Prices shown are estimates per session. Your exact plan and fee are confirmed at your first assessment. Most major insurers accepted.</p>
    </main>
    <Footer />
  </div>
  <ChatWidget client:load />
</Layout>
