---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/clinics-physio/BrandNav';
import Footer from '../../../components/demos/clinics-physio/Footer';
import FaqAccordion from '../../../components/demos/clinics-physio/FaqAccordion';
import ChatWidget from '../../../components/demos/clinics-physio/ChatWidget';
import { brand } from '../../../components/demos/clinics-physio/data';
---

<Layout title="Patient Info & FAQ — Verdant Physio">
  <Header client:load />
  <BrandNav client:load />
  <div class="min-h-screen bg-emerald-50/40 font-sans">
    <section class="pt-32 pb-12 bg-gradient-to-b from-emerald-700 to-teal-600">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block px-3 py-1 rounded-full bg-white/15 text-emerald-50 text-xs font-medium mb-4">Patient Info</span>
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white mb-3">Everything you need to know</h1>
        <p class="text-emerald-50/90 max-w-2xl mx-auto">Your first visit, what to bring, insurance and hours — all in one place.</p>
      </div>
    </section>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <h2 class="font-display font-bold text-2xl text-slate-800 mb-5">Frequently asked questions</h2>
          <FaqAccordion client:visible />
        </div>

        <aside class="space-y-5">
          <div class="bg-white rounded-2xl border border-emerald-100 p-6">
            <h3 class="font-display font-bold text-slate-800 mb-4">Opening hours</h3>
            <ul class="space-y-2.5 text-sm">
              {brand.hours.map((h) => (
                <li class="flex justify-between gap-4">
                  <span class="text-slate-500">{h.day}</span>
                  <span class="font-medium text-slate-800">{h.time}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white rounded-2xl border border-emerald-100 p-6">
            <h3 class="font-display font-bold text-slate-800 mb-4">Visit us</h3>
            <p class="text-sm text-slate-600 mb-1">{brand.address}</p>
            <p class="text-sm text-slate-600 mb-1">{brand.phone}</p>
            <p class="text-sm text-slate-600">{brand.email}</p>
            <div class="mt-4 h-32 rounded-xl bg-gradient-to-br from-emerald-100 to-teal-100 flex items-center justify-center text-emerald-600 text-sm font-medium">
              📍 Free patient parking
            </div>
          </div>

          <div class="bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl p-6 text-white">
            <h3 class="font-display font-bold mb-2">First time here?</h3>
            <p class="text-sm text-emerald-50/90 mb-4">No referral needed. Just book online and we’ll take care of the rest.</p>
            <a href="/demo/clinics-physio/book" class="block text-center py-2.5 rounded-full bg-white text-emerald-700 font-semibold text-sm hover:shadow-lg transition-shadow">Book your first visit</a>
          </div>
        </aside>
      </div>
    </main>
    <Footer />
  </div>
  <ChatWidget client:load />
</Layout>
