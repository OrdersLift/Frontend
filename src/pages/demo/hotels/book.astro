---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/hotels/BrandNav';
import BrandFooter from '../../../components/demos/hotels/BrandFooter';
import Concierge from '../../../components/demos/hotels/Concierge';
import BookingFlow from '../../../components/demos/hotels/BookingFlow';
import { hours } from '../../../components/demos/hotels/data';
---

<Layout title="Book Your Stay · Maple & Mist">
  <Header client:load />
  <BrandNav client:load />
  <main class="bg-[#fbf7ef] min-h-screen">
    <section class="bg-[#1c2b24] pt-32 pb-14">
      <div class="max-w-7xl mx-auto px-6">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-500">Direct booking · best rate guaranteed</span>
        <h1 class="mt-2 font-serif text-4xl sm:text-5xl text-amber-50">Book Your Stay</h1>
        <p class="mt-3 max-w-xl text-emerald-100/80">
          Choose your dates, see live availability, and reserve in under a minute. No fees, free cancellation up to 48h before arrival.
        </p>
        <div class="mt-5 flex flex-wrap gap-4 text-sm text-emerald-100/70">
          <span>Check-in {hours.checkIn}</span>
          <span>·</span>
          <span>Check-out {hours.checkOut}</span>
          <span>·</span>
          <span>Breakfast {hours.breakfast}</span>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-12">
      <BookingFlow client:load />
    </section>
  </main>
  <BrandFooter />
  <Concierge client:load />
</Layout>
