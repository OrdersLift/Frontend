---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/real-estate/BrandNav';
import BookingForm from '../../../components/demos/real-estate/BookingForm';
import Footer from '../../../components/demos/real-estate/Footer';
import Chatbot from '../../../components/demos/real-estate/Chatbot';
---

<Layout title="Book a Viewing — Aurelia Estates">
  <div class="min-h-screen bg-emerald-50/30 font-sans">
    <Header client:load />
    <BrandNav client:load />
    <main>
      <section class="bg-[#0b1f17] pt-32 pb-12 relative overflow-hidden">
        <div class="absolute -top-24 right-1/4 w-96 h-96 rounded-full bg-emerald-600/20 blur-3xl"></div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <p class="text-xs uppercase tracking-[0.3em] text-emerald-400 font-semibold">Step inside</p>
          <h1 class="mt-2 font-serif text-4xl sm:text-5xl text-emerald-50">Book a viewing</h1>
          <p class="mt-3 text-emerald-100/70 max-w-xl">Choose a property and a time that suits you. We'll confirm within the hour.</p>
        </div>
      </section>
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <BookingForm client:load />
      </section>
    </main>
    <Footer />
    <Chatbot client:load />
  </div>
</Layout>
