---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/gyms-fitness/BrandNav';
import BrandFooter from '../../../components/demos/gyms-fitness/BrandFooter';
import Scheduler from '../../../components/demos/gyms-fitness/Scheduler';
import ChatWidget from '../../../components/demos/gyms-fitness/ChatWidget';
---

<Layout title="Classes & Schedule | PULSE FORGE">
  <Header client:load />
  <BrandNav client:load />
  <main class="min-h-screen bg-black">
    <section class="pt-32 pb-16 relative overflow-hidden">
      <div class="pointer-events-none absolute -top-10 left-1/3 h-80 w-80 rounded-full bg-lime-500/15 blur-[120px]"></div>
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <span class="inline-block rounded-full border border-lime-400/30 bg-lime-400/10 px-4 py-1.5 text-sm font-bold text-lime-300">120 classes / week</span>
        <h1 class="mt-5 font-display text-4xl sm:text-5xl font-extrabold text-white">Weekly Timetable</h1>
        <p class="mt-3 max-w-xl text-zinc-400">Pick a day, find your fight, and lock your spot. Spots update live — and they fill fast.</p>
        <div class="mt-10">
          <Scheduler client:load />
        </div>
      </div>
    </section>
  </main>
  <BrandFooter />
  <ChatWidget client:load />
</Layout>
