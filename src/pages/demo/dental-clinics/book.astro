---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/dental-clinics/BrandNav';
import BrandFooter from '../../../components/demos/dental-clinics/BrandFooter';
import BookingFlow from '../../../components/demos/dental-clinics/BookingFlow';
import ChatWidget from '../../../components/demos/dental-clinics/ChatWidget';
---

<Layout title="Book an Appointment — Lumina Dental">
  <Header client:load />
  <BrandNav client:load />
  <div class="min-h-screen bg-slate-50">
    <main>
      <section class="bg-gradient-to-b from-slate-900 to-teal-800 pt-32 pb-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="text-teal-300 font-semibold">Book in under 2 minutes</p>
          <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white mt-2">Reserve your visit</h1>
          <p class="text-teal-50/80 mt-3 max-w-xl mx-auto">Pick a treatment, your favorite dentist and a time that suits you. Instant confirmation — no phone calls.</p>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <BookingFlow client:load />
      </section>
    </main>
    <BrandFooter />
  </div>
  <ChatWidget client:load />
</Layout>
