---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header';
import BrandNav from '../../../components/demos/dental-clinics/BrandNav';
import BrandFooter from '../../../components/demos/dental-clinics/BrandFooter';
import FaqAccordion from '../../../components/demos/dental-clinics/FaqAccordion';
import ChatWidget from '../../../components/demos/dental-clinics/ChatWidget';
---

<Layout title="Patient FAQ — Lumina Dental">
  <Header client:load />
  <BrandNav client:load />
  <div class="min-h-screen bg-slate-50">
    <main>
      <section class="bg-gradient-to-b from-slate-900 to-teal-800 pt-32 pb-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="text-teal-300 font-semibold">Patient FAQ</p>
          <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white mt-2">Good to know</h1>
          <p class="text-teal-50/80 mt-3 max-w-xl mx-auto">Insurance, comfort, prep and hours — answered. Still stuck? Ask Lumi, our AI assistant.</p>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <FaqAccordion client:visible />
      </section>
    </main>
    <BrandFooter />
  </div>
  <ChatWidget client:load />
</Layout>
